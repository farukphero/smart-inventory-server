<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your PB Account</title>
    <style>
      body {
        font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
        background-color: #f4f6f8;
        margin: 0;
        padding: 0;
        color: #333;
      }
      .email-container {
        max-width: 600px;
        margin: 40px auto;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        overflow: hidden;
      }
      .header {
        background-color: #01868f;
        color: #fff;
        text-align: center;
        padding: 25px 20px;
      }
      .header h1 {
        margin: 0;
        font-size: 22px;
        font-weight: 600;
        letter-spacing: 0.5px;
      }
      .content {
        padding: 30px 25px;
      }
      .content p {
        line-height: 1.6;
        font-size: 15px;
        margin: 10px 0;
        color: #444;
      }
      .code-box {
        background: #f3f4f6;
        padding: 15px 0;
        border-radius: 8px;
        text-align: center;
        margin: 25px 0;
      }
      .code-box h2 {
        font-size: 32px;
        color: #0c5b69;
        letter-spacing: 4px;
        margin: 0;
      }
      .footer {
        border-top: 1px solid #e5e7eb;
        text-align: center;
        padding: 15px 0;
        background-color: #fafafa;
        font-size: 13px;
        color: #666;
      }
      .footer a {
        color: #01868f;
        text-decoration: none;
        font-weight: 500;
      }
      @media (max-width: 600px) {
        .email-container {
          margin: 20px;
          border-radius: 10px;
        }
        .header h1 {
          font-size: 20px;
        }
      }
    </style>
  </head>

  <body>
    <div class="email-container">
      <div class="header">
        <h1>Verify Your PB Account</h1>
      </div>

      <div class="content">
        <p>Hi <strong><%= name %></strong>,</p>
        <p>
          Welcome to <strong>PB</strong>! We're excited to have you on board.
          To complete your profile, please verify your email address using the code below.
        </p>

        <div class="code-box">
          <h2><%= code %></h2>
        </div>

        <p>
          This verification code is valid for <strong>5 minutes</strong>.
          Please do not share it with anyone for security reasons.
        </p>

        <p>
          If you didn’t create an account on PB, you can safely ignore this message.
        </p>

        <p style="margin-top: 25px;">
          Thanks for joining us,<br />
          <strong>The PB Team</strong>
        </p>
      </div>

      <div class="footer">
        <p>
          Need help? Visit our <a href="https://puronobondu.com/help" target="_blank">Help Center</a>
          or contact <a href="mailto:support@puronobondu.com">support@puronobondu.com</a>
        </p>
        <p>© <%= new Date().getFullYear() %> PB. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
